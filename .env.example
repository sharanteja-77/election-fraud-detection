# MongoDB Atlas / free cluster connection string
# Replace <username>, <password>, <cluster-address> with your Atlas credentials
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-address>/?retryWrites=true&w=majority
DB_NAME=election_fraud_db
SECRET_KEY=change-this-to-a-long-random-string

# Optional: use same upload folder as local
UPLOAD_FOLDER=static/uploads
# Turn off debug in production
FLASK_DEBUG=False
